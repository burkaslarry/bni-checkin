# BNI Anchor Check-in System - Environment Variables
# Copy this file to .env and fill in your actual values

# Supabase Database Password
# Get this from: https://supabase.com/dashboard > Your Project > Settings > Database
# Look for "Database password" (the one you set when creating the project)
SUPABASE_DB_PASSWORD=your_supabase_password_here

# Optional: DeepSeek API (already configured in application.properties)
# DEEPSEEK_API_KEY=your_deepseek_api_key

# How to use:
# 1. Copy this file: cp .env.example .env
# 2. Edit .env and add your actual Supabase password
# 3. Load before running: export $(cat .env | xargs) && ./run.sh
